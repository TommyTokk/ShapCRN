<?xml version="1.0" encoding="UTF-8"?>
<sbml xmlns="http://www.sbml.org/sbml/level3/version2/core" level="3" version="2">
  <model id="Mixed_Kinetics_Model_Volume_Corrected" name="Model with Volume Scaled Kinetics">
    
    <listOfFunctionDefinitions>
      
      <functionDefinition id="f_mass_action_reversible_vol">
        <math xmlns="http://www.w3.org/1998/Math/MathML">
          <lambda>
              <bvar><ci> k_fwd </ci></bvar>
              <bvar><ci> k_rev </ci></bvar>
              <bvar><ci> reactant </ci></bvar>
              <bvar><ci> product </ci></bvar>
             
              <apply>
                <minus/>
                <apply>
                  <times/>
                  <ci> k_fwd </ci>
                  <ci> reactant </ci>
                </apply>
                <apply>
                  <times/>
                  <ci> k_rev </ci>
                  <ci> product </ci>
                </apply>
              </apply>
            </lambda>
        </math>
      </functionDefinition>

      <functionDefinition id="f_MM_vol">
        <math xmlns="http://www.w3.org/1998/Math/MathML">
          <lambda>
            <bvar><ci> Vmax </ci></bvar>
            <bvar><ci> Km </ci></bvar>
            <bvar><ci> substrate </ci></bvar>
            <bvar><ci> volume </ci></bvar> 
            <apply>
              <times/>
              <ci> volume </ci>
              <apply>
                <divide/>
                <apply>
                  <times/>
                  <ci> Vmax </ci>
                  <ci> substrate </ci>
                </apply>
                <apply>
                  <plus/>
                  <ci> Km </ci>
                  <ci> substrate </ci>
                </apply>
              </apply>
            </apply>
          </lambda>
        </math>
      </functionDefinition>

      <functionDefinition id="f_mass_action_compartment_explicit">
        <math xmlns="http://www.w3.org/1998/Math/MathML">
          <lambda>
            <bvar><ci> compartment_vol </ci></bvar>
            <bvar><ci> k_fwd </ci></bvar>
            <bvar><ci> k_rev </ci></bvar>
            <bvar><ci> reactant </ci></bvar>
            <bvar><ci> product </ci></bvar>
            <apply>
              <times/>
              <ci> compartment_vol </ci>
              <apply>
                <minus/>
                <apply>
                  <times/>
                  <ci> k_fwd </ci>
                  <ci> reactant </ci>
                </apply>
                <apply>
                  <times/>
                  <ci> k_rev </ci>
                  <ci> product </ci>
                </apply>
              </apply>
            </apply>
          </lambda>
        </math>
      </functionDefinition>

    </listOfFunctionDefinitions>

    <listOfCompartments>
      <compartment id="cell" size="1.5" constant="true"/>
    </listOfCompartments>

    <listOfSpecies>
      <species id="S1" compartment="cell" initialConcentration="10" hasOnlySubstanceUnits="false" boundaryCondition="false" constant="false"/>
      <species id="P1" compartment="cell" initialConcentration="0" hasOnlySubstanceUnits="false" boundaryCondition="false" constant="false"/>
      
      <species id="S2" compartment="cell" initialConcentration="10" hasOnlySubstanceUnits="false" boundaryCondition="false" constant="false"/>
      <species id="P2" compartment="cell" initialConcentration="0" hasOnlySubstanceUnits="false" boundaryCondition="false" constant="false"/>
      
      <species id="S3" compartment="cell" initialConcentration="10" hasOnlySubstanceUnits="false" boundaryCondition="false" constant="false"/>
      <species id="P3" compartment="cell" initialConcentration="0" hasOnlySubstanceUnits="false" boundaryCondition="false" constant="false"/>

      <species id="S4" compartment="cell" initialConcentration="10" hasOnlySubstanceUnits="false" boundaryCondition="false" constant="false"/>
      <species id="P4" compartment="cell" initialConcentration="0" hasOnlySubstanceUnits="false" boundaryCondition="false" constant="false"/>

      <species id="S5" compartment="cell" initialConcentration="10" hasOnlySubstanceUnits="false" boundaryCondition="false" constant="false"/>
      <species id="P5" compartment="cell" initialConcentration="0" hasOnlySubstanceUnits="false" boundaryCondition="false" constant="false"/>
    </listOfSpecies>

    <listOfReactions>
      
      <reaction id="R1_MassAction_Explicit" reversible="false" fast="false">
        <listOfReactants>
          <speciesReference species="S1" stoichiometry="1" constant="true"/>
        </listOfReactants>
        <listOfProducts>
          <speciesReference species="P1" stoichiometry="1" constant="true"/>
        </listOfProducts>
        <kineticLaw>
          <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
              <times/>
              <ci> cell </ci>  <ci> k1 </ci>
              <ci> S1 </ci>
            </apply>
          </math>
          <listOfLocalParameters>
            <localParameter id="k1" value="0.1"/>
          </listOfLocalParameters>
        </kineticLaw>
      </reaction>

      <reaction id="R2_MassAction_Function" reversible="true" fast="false">
        <listOfReactants>
          <speciesReference species="S2" stoichiometry="1" constant="true"/>
        </listOfReactants>
        <listOfProducts>
          <speciesReference species="P2" stoichiometry="1" constant="true"/>
        </listOfProducts>
        <kineticLaw>
          <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
              <times/>
              <ci>cell</ci>
              <apply>
                <ci> f_mass_action_reversible_vol </ci>
                <ci> kf </ci>
                <ci> kr </ci>
                <ci> S2 </ci>
                <ci> P2 </ci>
              </apply>
              </apply>
          </math>
          <listOfLocalParameters>
            <localParameter id="kf" value="0.1"/>
            <localParameter id="kr" value="0.05"/> 
          </listOfLocalParameters>
        </kineticLaw>
      </reaction>

      <reaction id="R3_MM_Explicit" reversible="false" fast="false">
        <listOfReactants>
          <speciesReference species="S3" stoichiometry="1" constant="true"/>
        </listOfReactants>
        <listOfProducts>
          <speciesReference species="P3" stoichiometry="1" constant="true"/>
        </listOfProducts>
        <kineticLaw>
          <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
              <times/>
              <ci> cell </ci> <apply>
                <divide/>
                <apply>
                  <times/>
                  <ci> Vmax </ci>
                  <ci> S3 </ci>
                </apply>
                <apply>
                  <plus/>
                  <ci> Km </ci>
                  <ci> S3 </ci>
                </apply>
              </apply>
            </apply>
          </math>
          <listOfLocalParameters>
            <localParameter id="Vmax" value="1.0"/>
            <localParameter id="Km" value="2.0"/>
          </listOfLocalParameters>
        </kineticLaw>
      </reaction>

      <reaction id="R4_MM_Function" reversible="false" fast="false">
        <listOfReactants>
          <speciesReference species="S4" stoichiometry="1" constant="true"/>
        </listOfReactants>
        <listOfProducts>
          <speciesReference species="P4" stoichiometry="1" constant="true"/>
        </listOfProducts>
        <kineticLaw>
          <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
              <ci> f_MM_vol </ci>
              <ci> Vmax_local </ci>
              <ci> Km_local </ci>
              <ci> S4 </ci>
              <ci> cell </ci> </apply>
          </math>
          <listOfLocalParameters>
            <localParameter id="Vmax_local" value="1.5"/>
            <localParameter id="Km_local" value="2.5"/>
          </listOfLocalParameters>
        </kineticLaw>
      </reaction>

      <reaction id="R5_New_Structure" reversible="true" fast="false">
        <listOfReactants>
          <speciesReference species="S5" stoichiometry="1" constant="true"/>
        </listOfReactants>
        <listOfProducts>
          <speciesReference species="P5" stoichiometry="1" constant="true"/>
        </listOfProducts>
        <kineticLaw>
          <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
              <ci> f_mass_action_compartment_explicit </ci>
              <ci> cell </ci>
              <ci> kf_new </ci>
              <ci> kr_new </ci>
              <ci> S5 </ci>
              <ci> P5 </ci>
            </apply>
          </math>
          <listOfLocalParameters>
            <localParameter id="kf_new" value="0.2"/>
            <localParameter id="kr_new" value="0.1"/>
          </listOfLocalParameters>
        </kineticLaw>
      </reaction>

    </listOfReactions>
  </model>
</sbml>
